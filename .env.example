# Seramikcim ortam değişkenleri örneği
# Kullanım: bu dosyayı `.env` olarak kopyala, gerekirse değerleri düzenle.
# Vite VITE_ prefix'li değişkenleri build sırasında client'a expose eder.

VITE_API_BASE_URL=http://localhost:8000
VITE_APP_VERSION=1.0.0
VITE_MAX_FILE_SIZE_MB=50
VITE_CATALOG_PATH=./public/catalog.json
